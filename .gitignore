# Data — anchored to repo root so src/data/ stays tracked.
/data/
*.csv
*.xlsx
*.parquet

# Models — anchored to repo root so src/models/ stays tracked.
/models/
*.pkl
*.joblib

# Experiment outputs (timestamped run folders per roadmap §6) are not
# versioned by default -- except one frozen snapshot, committed specifically
# so the deployed dashboard has a model to load (dashboard/app.py's
# artifact-discovery guard needs at least one outputs/*/model_v1.joblib to
# exist; Streamlit Cloud only sees what's committed to the repo).
/outputs/*
!/outputs/20260705T224938Z/
!/outputs/20260705T224938Z/**

